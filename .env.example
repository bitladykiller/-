# Deepseek 在线模型 API 的配置
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat

# 通过 Ollama 提供的模型服务地址
OLLAMA_BASE_URL=http://192.168.110.131:11434  # 注意：这里需要根据实际情况修改

OLLAMA_AGENT_MODEL=qwen2.5:32b  # Agent模型
OLLAMA_EMBEDDING_MODEL=bge-m3  # 词向量模型

# 模型服务选择
AGENT_SERVICE=deepseek  # 或 ollama    

# 基础 MySQL 连接配置
# docker compose 启动时会被根目录 `.env.docker` 中的容器地址覆盖。
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=assist_gen

# 基础 Neo4j 连接配置
# docker compose 启动时会被根目录 `.env.docker` 中的容器地址覆盖。
NEO4J_URL=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_DATABASE=neo4j

# 基础 Redis 连接配置
# docker compose 启动时会被根目录 `.env.docker` 中的容器地址覆盖。
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
