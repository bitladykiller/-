# Docker Compose 覆盖项。
# 这个文件只覆盖容器内基础设施地址和 compose 默认凭据，不重复保存 API Key。
# compose 会先读取 `app/.env`，再用这里的值覆盖其中的基础连接配置。

DB_HOST=mysql
DB_PORT=3306
DB_USER=kefu_user
DB_PASSWORD=1234
DB_NAME=kefu_agent

NEO4J_URL=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=12345678
NEO4J_DATABASE=neo4j

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

MILVUS_HOST=milvus
MILVUS_PORT=19530
